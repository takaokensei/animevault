# ============================================================
#  Zenith SaaS Backend — Variáveis de Ambiente
#  Copie este arquivo para ".env" e preencha os valores reais.
#  NUNCA commite o arquivo ".env" com valores reais.
# ============================================================

# --- Segurança JWT (OBRIGATÓRIO) ---
# Gere uma string aleatória forte, ex:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Mínimo de 32 caracteres. O servidor recusa iniciar sem isso.
JWT_SECRET=<sua-string-aleatoria-de-pelo-menos-32-caracteres>

# --- CORS (origens permitidas) ---
# Lista separada por vírgula dos domínios que podem chamar este backend.
# Ex. produção: https://app.zenith.com,https://www.zenith.com
# Em desenvolvimento, inclui as portas do Vite (1420) e callback (1421)
ALLOWED_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,http://localhost:1421,http://127.0.0.1:1421

# --- Banco de Dados (opcional) ---
# Se não definida, usa o arquivo local "data-store.json" (dev apenas).
# Para staging/produção, defina uma connection string PostgreSQL válida:
# DATABASE_URL=postgresql://user:password@host:5432/zenith_db
DATABASE_URL=

# --- Porta do servidor ---
PORT=1422
